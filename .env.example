# ---------------------------------------------------------------------------
# TicketBari Client (Next.js) - Environment Variables
# Copy this file to ".env.local" and fill in your own values.
# Next.js only exposes variables prefixed with NEXT_PUBLIC_ to the browser.
# ---------------------------------------------------------------------------

# Your deployed/local server URL
NEXT_PUBLIC_API_URL=http://localhost:5000

# imgbb — used for ticket image uploads (Add Ticket form)
# Get a free key at https://api.imgbb.com/
NEXT_PUBLIC_IMGBB_API_KEY=your_imgbb_api_key

# Stripe publishable key (safe to expose on the client)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
